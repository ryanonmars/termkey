{
  "name": "termkey",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "termkey",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.9.3"
      }
    },
    "apps/extension": {
      "name": "@termkey/extension",
      "version": "0.0.1",
      "dependencies": {
        "@termkey/core": "0.0.1",
        "@termkey/types": "0.0.1"
      }
    },
    "node_modules/@termkey/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@termkey/extension": {
      "resolved": "apps/extension",
      "link": true
    },
    "node_modules/@termkey/types": {
      "resolved": "packages/types",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/core": {
      "name": "@termkey/core",
      "version": "0.0.1"
    },
    "packages/types": {
      "name": "@termkey/types",
      "version": "0.0.1"
    }
  }
}

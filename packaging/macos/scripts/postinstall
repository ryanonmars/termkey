#!/usr/bin/env bash

set -euo pipefail

binary_path="/usr/local/bin/termkey"
app_path="/Applications/TermKey.app"
app_binary_path="$app_path/Contents/Resources/bin/termkey"

if [[ -f "$binary_path" ]]; then
  chmod 755 "$binary_path"
  xattr -d com.apple.quarantine "$binary_path" 2>/dev/null || true
fi

if [[ -d "$app_path" ]]; then
  xattr -dr com.apple.quarantine "$app_path" 2>/dev/null || true
fi

if [[ -f "$app_binary_path" ]]; then
  chmod 755 "$app_binary_path"
  xattr -d com.apple.quarantine "$app_binary_path" 2>/dev/null || true
fi

exit 0

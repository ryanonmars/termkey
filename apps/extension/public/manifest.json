{
  "manifest_version": 3,
  "name": "TermKey Extension",
  "version": "0.0.1",
  "description": "Autofill and credential manager",
  "permissions": ["storage", "activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ]
}

#!/usr/bin/env bash

set -euo pipefail

binary_path="/usr/local/bin/termkey"
native_host_binary_path="/usr/local/bin/termkey-native-host"
app_path="/Applications/TermKey.app"
uninstall_app_path="/Applications/Uninstall TermKey.app"
app_binary_path="$app_path/Contents/Resources/bin/termkey"
app_native_host_binary_path="$app_path/Contents/Resources/bin/termkey-native-host"

if [[ -f "$binary_path" ]]; then
  chmod 755 "$binary_path"
  xattr -d com.apple.quarantine "$binary_path" 2>/dev/null || true
fi

if [[ -f "$native_host_binary_path" ]]; then
  chmod 755 "$native_host_binary_path"
  xattr -d com.apple.quarantine "$native_host_binary_path" 2>/dev/null || true
fi

if [[ -d "$app_path" ]]; then
  xattr -dr com.apple.quarantine "$app_path" 2>/dev/null || true
fi

if [[ -d "$uninstall_app_path" ]]; then
  xattr -dr com.apple.quarantine "$uninstall_app_path" 2>/dev/null || true
fi

if [[ -f "$app_binary_path" ]]; then
  chmod 755 "$app_binary_path"
  xattr -d com.apple.quarantine "$app_binary_path" 2>/dev/null || true
fi

if [[ -f "$app_native_host_binary_path" ]]; then
  chmod 755 "$app_native_host_binary_path"
  xattr -d com.apple.quarantine "$app_native_host_binary_path" 2>/dev/null || true
fi

exit 0
